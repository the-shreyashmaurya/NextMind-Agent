# # NEXTMIND CONFIGURATION EXAMPLES
# # Rename this file to .env and fill in the keys

# # OpenRouter (Unified API for all models)
# OPENROUTER_API_KEY=your_openrouter_api_key

# # OpenAI (For embeddings)
# OPENAI_API_KEY=your_openai_api_key

# # Retrieval APIs
# TAVILY_API_KEY=your_tavily_api_key
# OPENALEX_EMAIL=your_email@example.com
# SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key
# LENS_API_KEY=your_lens_patent_api_key

# # Vector DB
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your_qdrant_api_key

# # API Security
# NEXTMIND_API_KEY=NEXTMIND_API_YOUR_KEY123

# # Storage (SQLite by default, Redis for production)
# DATABASE_URL=sqlite:///./nextmind.db
# REDIS_URL=redis://localhost:6379
